---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import ProfilePhoto from '../assets/seungwon Kim profile photo.jpg';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);

const topics = ['MBSE', 'SysML', 'Systems Engineering', 'Architecture', 'AI'];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.intro {
				display: flex;
				align-items: center;
				gap: 1.5rem;
				margin-bottom: 2rem;
			}
			.intro img {
				width: 110px;
				height: 110px;
				border-radius: 50%;
				object-fit: cover;
				flex-shrink: 0;
				box-shadow: var(--box-shadow);
			}
			.intro h1 {
				font-size: 2rem;
				margin: 0 0 0.3em 0;
			}
			.intro .tagline {
				margin: 0 0 0.5em 0;
				color: rgb(var(--gray-dark));
				font-size: 1.05rem;
				line-height: 1.5;
			}
			.intro .about-link {
				font-size: 0.95rem;
			}
			.topics {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				margin-bottom: 2.5rem;
			}
			.topics span {
				font-size: 0.85rem;
				padding: 0.3em 0.85em;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 999px;
				color: rgb(var(--gray));
			}
			.posts h2 {
				font-size: 1.3rem;
				margin-bottom: 1rem;
			}
			.posts ul {
				list-style: none;
				margin: 0 0 1.5rem 0;
				padding: 0;
			}
			.posts li {
				margin-bottom: 1rem;
				padding-bottom: 1rem;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.posts li a {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				gap: 1rem;
				text-decoration: none;
				color: rgb(var(--black));
			}
			.posts .post-title {
				font-weight: 600;
			}
			.posts li a:hover .post-title {
				color: var(--accent);
			}
			.posts .post-date {
				color: rgb(var(--gray));
				font-size: 0.85rem;
				white-space: nowrap;
				flex-shrink: 0;
			}
			@media (max-width: 720px) {
				.intro {
					flex-direction: column;
					text-align: center;
				}
				.posts li a {
					flex-direction: column;
					gap: 0.2rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="intro">
				<Image src={ProfilePhoto} alt="Seungwon Kim" width={220} height={220} />
				<div>
					<h1>Seungwon Kim</h1>
					<p class="tagline">
						Systems and solution engineer. I write about model-based systems engineering — and
						where it meets AI.
					</p>
					<a href="/about" class="about-link">More about me →</a>
				</div>
			</section>

			<div class="topics">
				{topics.map((t) => <span>{t}</span>)}
			</div>

			<section class="posts">
				<h2>Recent posts</h2>
				<ul>
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<span class="post-title">{post.data.title}</span>
									<span class="post-date">
										<FormattedDate date={post.data.pubDate} />
									</span>
								</a>
							</li>
						))
					}
				</ul>
				<a href="/blog">All posts →</a>
			</section>
		</main>
		<Footer />
	</body>
</html>
